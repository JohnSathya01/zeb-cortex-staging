{
  "rules": {
    "users": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'leadership'",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "assignments": {
      ".read": "auth != null",
      "$assignmentId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'leadership' || data.child('learnerId').val() === auth.uid)"
      }
    },
    "progress": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'leadership'",
      "$learnerId": {
        ".read": "auth != null && (auth.uid === $learnerId || root.child('users').child(auth.uid).child('role').val() === 'leadership' || root.child('reviewerAccess').child($learnerId).child(auth.uid).val() === true)",
        ".write": "auth != null && auth.uid === $learnerId"
      }
    },
    "reviewerAccess": {
      "$learnerId": {
        ".read": "auth != null && (auth.uid === $learnerId || root.child('users').child(auth.uid).child('role').val() === 'leadership')",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'leadership'"
      }
    },
    "assessments": {
      ".read": "auth != null",
      "$courseId": {
        "$chapterId": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'leadership'"
        }
      }
    },
    "notifications": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null"
      }
    },
    "courseConfigs": {
      ".read": "auth != null",
      "$courseId": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'leadership'"
      }
    },
    "cohorts": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'leadership'"
    },
    "exercises": {
      ".read": "auth != null",
      "$courseId": {
        "$chapterId": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'leadership'"
        }
      }
    },
    "exerciseRules": {
      ".read": "auth != null",
      "$courseId": {
        "$chapterId": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'leadership'"
        }
      }
    },
    "auditLogs": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'leadership'",
      ".write": "auth != null"
    },
    "coursePoints": {
      "$userId": {
        ".read": "auth != null && (auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'leadership')",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'leadership'"
      }
    },
    "chats": {
      "$assignmentId": {
        ".read": "auth != null && (root.child('assignments').child($assignmentId).child('learnerId').val() === auth.uid || root.child('assignments').child($assignmentId).child('reviewerId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'leadership')",
        ".write": "auth != null && (root.child('assignments').child($assignmentId).child('learnerId').val() === auth.uid || root.child('assignments').child($assignmentId).child('reviewerId').val() === auth.uid)"
      }
    }
  }
}
